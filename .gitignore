# Unity generated folders
/Library/
/Temp/
/Obj/
/Build/
/Builds/
/Logs/
/UserSettings/
/MemoryCaptures/
/Recordings/

# Unity generated files
*.csproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity crash and profiler output
sysinfo.txt
*.stackdump
*.trace

# IDE/editor folders
/.vs/
/.idea/
/.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app

# Keep Unity assets, metadata, packages, and project settings tracked.
!Assets/**/*.meta
!Packages/manifest.json
!Packages/packages-lock.json
!ProjectSettings/*.asset
