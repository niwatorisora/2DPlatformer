  entries:
  - key: wace1
    title: "\u958B\u5E55"
    text: "\u3042\u308B\u8001\u5A46\u304C\u6B7B\u306B\u3001\u5F14\u308F\u308C\u305F\u3002\n\u3042\u306A\u305F\u306F\u5589\u4ECF\u3060\u3002\n\u706B\u846C\u3055\u308C206\u306E\u9AA8\u304C\u5206\u96E2\u3057\u305F\u3053\u306E\u72B6\u6CC1\u3067\u3001\n\u771F\u306B\u300C\u3042\u306E\u8001\u5A46\u300D\u3060\u3063\u305F\u3068\u3044\u3048\u308B\u7D76\u5BFE\u306E\u4E00\u7247\u3092\u6C7A\u3081\u308B\u6B7B\u95D8\u304C\u5E55\u3092\u958B\u3051\u305F\u3002"
  - key: first_gameover
    title: "\u8F2A\u5EFB "
    text: "\u4EBA\u751F\u3068\u3044\u3046\u708E\u306B\u3068\u3063\u3066\u3001\u3042\u308B\u3044\u306F\u706B\u846C\u306E\u679C\u3066\u306E\u7523\u7269\u3068\u3057\u3066\u3002\n\u5589\u4ECF(\u3042\u306A\u305F)\u306F\u6B8B\u6ED3\u306B\u904E\u304E\u305A\u3001\u3069\u3046\u3057\u3088\u3046\u3082\u306A\u304F\u8106\u304B\u3063\u305F\u3002\n\u2026\u2026\u679C\u305F\u3057\u3066\u305D\u308C\u306F\u3001\u6B69\u307F\u3092\u6B62\u3081\u308B\u7406\u7531\u3068\u306A\u308B\u3060\u308D\u3046\u304B\uFF1F"
  - key: fireNrounds
    title: "\u8AAD\u7D4C "
    text: "\u91CD\u8981\u306A\u306E\u306F\u5185\u5BB9\u3060\u3063\u305F\u306E\u304B\u3001\u5F62\u5F0F\u3060\u3063\u305F\u306E\u304B\u3001\u96F0\u56F2\u6C17\u3060\u3063\u305F\u306E\u304B\u3002\n\u3069\u3046\u3042\u308C\u3001\u8AAD\u7D4C\u306F\u907A\u65CF\u306E\u5FC3\u3078\u3068\u6DF1\u304F\u6DF1\u304F\u67D3\u307F\u3053\u3093\u3067\u3044\u304F\u3002\n\u8001\u5A46\u306F\u305D\u306E\u9593\u3001\u305F\u3060\u7A4F\u3084\u304B\u306B\u6A2A\u305F\u308F\u3063\u3066\u3044\u305F\u3002\n\u3055\u3066\u3002\n\u7D4C\u5178\u3068\u306F\u3001\u8AB0\u306E\u305F\u3081\u306B\u3042\u308B\u306E\u3060\u308D\u3046\u304B\u3002"
  - key: arms
    title: "\u8155"
    text: "\u521D\u3081\u3066\u306F\u6016\u304F\u3066\u3001\u30B1\u30AC\u3082\u3057\u305F\u3002\n\u305D\u308C\u3067\u3082\u6BCE\u65E5\u7E70\u308A\u8FD4\u3057\u3066\u3001\u5C11\u3057\u305A\u3064\u6163\u308C\u3066\u3044\u304F\u3002\n\u4EBA\u53C2\u3001\u30B8\u30E3\u30AC\u30A4\u30E2\u3001\u6625\u83CA\u3001\u8C46\u8150\u3002\n\u306B\u3083\u3093\u3053\u306E\u624B\u3001\u5F15\u304D\u5207\u308A\u3001\u30DA\u30FC\u30B9\u3092\u5D29\u3055\u305A\u5C0F\u6C17\u5473\u3088\u304F\u3002\n\u5305\u4E01\u3092\u63E1\u308A\u3042\u306E\u4EBA\u3068\u306E\u6599\u7406\u3092\u4F5C\u3063\u305F\u65E5\u3005\u306F\u3001\u3069\u3046\u306B\u3082\u5E78\u305B\u3067\u4ED5\u65B9\u306A\u304B\u3063\u305F\u3002"
  - key: spine
    title: "\u810A\u690E"
    text: "\u982D\u306E\u4E0A\u3067\u3001\u8AB0\u304B\u306E\u8155\u304C\u307E\u3063\u3059\u3050\u306B\u6A2A\u3078\u3068\u632F\u308B\u308F\u308C\u305F\u3002\n\u8AB0\u306E\u3060\u3063\u305F\u306E\u3060\u308D\u3046\u3001\u305F\u3057\u304B\u2026\u2026\u89AA\u306E\u3002\n\u80CC\u306B\u3057\u305F\u67F1\u306B\u523B\u307E\u308C\u305F\u306E\u306F\u3001\u6210\u9577\u306E\u8ECC\u8DE1\u3002\n\u5FC5\u6B7B\u306B\u751F\u304D\u3066\u3001\u4F38\u3073\u305F\u80CC\u306E\u8A18\u9332\u3002\n\u3082\u306F\u3084\u306A\u3044\u751F\u5BB6\u3067\u306E\u3001\u9060\u3044\u3001\u9060\u3044\u601D\u3044\u51FA\u3002"
  - key: skull
    title: "\u982D\u84CB\u9AA8"
    text: "\u77BC\u306E\u88CF\u306B\u713C\u304D\u3064\u3044\u305F\u306E\u306F\u3001\u9280\u8272\u306E\u74B0\u3002\n\u3042\u306A\u305F\u306B\u624B\u3092\u5F15\u304B\u308C\u3001\u521D\u3081\u3066\u8DB3\u3092\u8E0F\u307F\u5165\u308C\u305F\u3042\u306E\u5E97\u3002\n\u843D\u3061\u7740\u3044\u305F\u7167\u660E\u304C\u3001\u3057\u304B\u3057\u3001\u307E\u3070\u3086\u304F\u7167\u3089\u3057\u51FA\u3057\u3066\u3044\u305F\u3082\u306E\u3002\n\u3053\u306E\u4EBA\u751F\u306E\u4E2D\u3067\u3001\u3042\u308C\u307B\u3069\u7F8E\u3057\u3044\u3082\u306E\u306F\u3042\u3063\u305F\u3060\u308D\u3046\u304B\uFF1F\n\u77B3\u3092\u5931\u3063\u305F\u304F\u307C\u307F\u304C\u3001\u305D\u308C\u3067\u3082\u306A\u304A\u898B\u3064\u3081\u3066\u3044\u305F\u3002"
  - key: pelvis
    title: "\u9AA8\u76E4"
    text: "\u8155\u3092\u4F1D\u3044\u3001\u8EAB\u4F53\u306E\u5965\u3078\u3002 \u307E\u3068\u3081\u3089\u308C\u305F\u8377\u7269\u3092\u904B\u3076\u306E\u306F\u3001\u8170\u306B\u304F\u308B\u3082\u306E\u3060\u3002
      \u300C\u4ECA\u307E\u3067\u3042\u308A\u304C\u3068\u3046\u300D\u3068\u3001 \u305D\u3046\u6B8B\u3057\u3066\u3042\u306E\u5B50\u304C\u65C5\u7ACB\u3063\u3066\u3044\u3063\u305F\u5F8C\u3002
      \u3042\u306A\u305F\u3068\u3075\u305F\u308A\u306E\u5BB6\u304C\u3001\u3069\u3046\u306B\u3082\u5E83\u304F\u601D\u3048\u305F\u3002 "
  - key: rib
    title: "\u808B\u9AA8"
    text: "\u6DF1\u304F\u5438\u3046\u3001\u6DF1\u304F\u5438\u3046\u3001\u6839\u3053\u305D\u304E\u5410\u304D\u51FA\u3059\u3002\u4E00\u62CD\u4F11\u3080\u3002
      \u547C\u5438\u306E\u30EA\u30BA\u30E0\u304C\u529B\u306E\u5F37\u5F31\u3092\u751F\u307F\u3001\u547D\u3092\u3064\u306A\u3044\u3067\u3044\u304F\u3002
      \u541B\u306E\u9854\u3092\u521D\u3081\u3066\u898B\u308B\u307E\u3067\u3001\u3042\u3068\u3082\u3046\u5C11\u3057\u3002
      \u305D\u306E\u6642\u306F\u3001\u547C\u5438\u3092\u843D\u3061\u7740\u3051\u308B\u3088\u308A\u3082\u3001\u8EAB\u3092\u6E05\u3081\u308B\u3088\u308A\u3082\u524D\u306B\u3002
      \u3042\u3042\u3001\u541B\u306E\u8A95\u751F\u3092\u795D\u3044\u305F\u3044\u3002 "
  - key: foot
    title: "\u8DB3"
    text: "\u8D70\u308B\u3001\u8E0F\u307F\u8FBC\u3080\u3001\u8DF3\u3076\u3001\u8DF3\u306D\u308B\u3002
      \u3042\u3075\u308C\u51FA\u308B\u6D3B\u529B\u306E\u3059\u3079\u3066\u3092\u3001\u8E8D\u52D5\u3078\u3068\u5909\u3048\u3066\u3044\u304F\u3002
      \u9060\u304F\u3078\u3001\u9060\u304F\u3078\u3002\u3082\u3063\u3068\u901F\u304F\u3001\u3082\u3063\u3068\u901F\u304F\u3002
      \u6C42\u3081\u308B\u306E\u306F\u52DD\u5229\u3002\u305D\u3057\u3066\u3001\u305D\u306E\u305A\u3063\u3068\u624B\u524D\u306B\u3042\u308B\u9AD8\u63DA\u3002
      \u30B0\u30E9\u30A6\u30F3\u30C9\u306E\u4E0A\u3067\u3001\u91CD\u529B\u3060\u3051\u304C\u79C1\u3092\u7E1B\u3063\u3066\u3044\u305F\u3002 "
  - key: ring
    title: "\u6307\u8F2A"
    text: "\u3044\u3061\u3070\u3093\u601D\u3044\u8FD4\u3057\u305F\u306E\u306F\u3001\u8A95\u751F\u65E5\u306E\u6B21\u306E\u6708\u3002
      \u6E7F\u3063\u305F\u7A7A\u6C17\u306E\u4E2D\u3067\u3001\u3068\u3082\u306B\u9078\u3093\u3060\u5186\u74B0\u304C\u3002
      \u8A95\u751F\u77F3\u306E\u7DD1\u8272\u306E\u8F1D\u304D\u304C\u3001\u751F\u304D\u3066\u304D\u305F\u7406\u7531\u306B\u601D\u3048\u305F\u3042\u306E\u65E5\u3002
      \u7121\u7406\u3092\u627F\u77E5\u3067\u304A\u9858\u3044\u3057\u307E\u3059\u3002
      \u3069\u3046\u304B\u3001\u79C1\u306E\u85AC\u6307\u306B\u3064\u3051\u3066\u3001\u68FA\u306B\u53CE\u3081\u3066\u304F\u3060\u3055\u3044\u3002 "
