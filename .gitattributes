# Unity YAML files — use UnityYAMLMerge for conflict resolution
*.unity     merge=unityyamlmerge eol=lf
*.prefab    merge=unityyamlmerge eol=lf
*.asset     merge=unityyamlmerge eol=lf
*.meta      merge=unityyamlmerge eol=lf
*.mat       merge=unityyamlmerge eol=lf
*.anim      merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf
*.overrideController merge=unityyamlmerge eol=lf
*.physicsMaterial2D  merge=unityyamlmerge eol=lf

# C# source
*.cs  text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf

# Binary assets — never text-process or merge
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.psd     binary
*.tga     binary
*.tiff    binary
*.bmp     binary
*.fbx     binary
*.mp3     binary
*.wav     binary
*.ogg     binary
*.mp4     binary
*.mov     binary
*.ttf     binary
*.otf     binary
*.dll     binary
*.so      binary
